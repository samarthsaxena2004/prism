# Cerebras API
CEREBRAS_API_KEY=your_key_here

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Google AI Studio (free from aistudio.google.com)
GOOGLE_API_KEY=your_key_here

# Tavily (free from tavily.com)
TAVILY_API_KEY=your_key_here

# OpenRouter — powers the real GPU side of the Cerebras-vs-GPU comparison.
# Get a key at https://openrouter.ai/keys (free tier includes vision models).
OPENROUTER_API_KEY=your_key_here

# Optional: comma-separated fallback chain for the GPU pipeline. The first
# model that answers a probe is used for the whole run. Defaults to a chain
# of free vision-capable models. Override if you want a specific model:
# OPENROUTER_GPU_MODELS=meta-llama/llama-3.2-90b-vision-instruct,qwen/qwen-2.5-vl-72b-instruct