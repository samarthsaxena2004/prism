# Cerebras API
CEREBRAS_API_KEY=your_key_here

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Google AI Studio (free from aistudio.google.com)
GOOGLE_API_KEY=your_key_here

# Speed-comparison baseline model (optional). Default gemini-2.5-flash has only
# 20 free requests/day; enable billing to keep it, or switch to a higher free
# quota model, e.g. GEMINI_BASELINE_MODEL=gemini-2.0-flash
# GEMINI_BASELINE_MODEL=gemini-2.5-flash

# Tavily (free from tavily.com)
TAVILY_API_KEY=your_key_here
